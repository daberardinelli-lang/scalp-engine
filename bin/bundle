#!/usr/bin/env ruby
# frozen_string_literal: true

#
# This file was generated by Bundler.
#
# The application's dependencies are listed in /rails/Gemfile
# and frozen in /rails/Gemfile.lock.
#

require "rubygems"

m = Module.new do
  module_function

  def invoked_as_script?
    File.expand_path($0) == File.expand_path(__FILE__)
  end

  def env_var_version
    ENV["BUNDLER_VERSION"]
  end

  def cli_arg_version
    return unless invoked_as_script?
    return unless "update".start_with?(ARGV.first || " ")

    bundler_version = nil
    update_index = nil
    ARGV.each_with_index do |arg, index|
      if update_index && update_index.next == index && arg =~ Gem::Version::ANCHORED_VERSION_PATTERN
        bundler_version = arg
      end
      next unless arg =~ /\A--bundler(?:[= ](#{Gem::Version::VERSION_PATTERN}))?\z/
      bundler_version = $1
      update_index = index
    end
    bundler_version
  end

  def bundler_version_to_load
    env_var_version || cli_arg_version
  end

  def load_bundler!
    $LOAD_PATH.unshift(*Dir[Gem.path.map { |p| File.join(p, "gems/bundler-*/lib") }])
    require "bundler"
  end

  def invoke_bundler!
    load Gem.bin_path("bundler", "bundle") if invoked_as_script?
  end
end

m.load_bundler!
m.invoke_bundler!
