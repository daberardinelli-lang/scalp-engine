# ─── App ───────────────────────────────────────────────
RAILS_ENV=development
SECRET_KEY_BASE=changeme_run_rails_secret
RAILS_MASTER_KEY=

# ─── Database ──────────────────────────────────────────
DATABASE_URL=postgresql://webradar:password@postgres:5432/webradar_development
POSTGRES_USER=webradar
POSTGRES_PASSWORD=password
POSTGRES_DB=webradar_development

# ─── Redis ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MinIO (S3-compatible) ─────────────────────────────
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=webradar
MINIO_REGION=us-east-1

# ─── Google Places API ─────────────────────────────────
GOOGLE_PLACES_API_KEY=

# ─── Anthropic (Claude) ────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Email ─────────────────────────────────────────────
SENDGRID_API_KEY=
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_WEBHOOK_SECRET=    # Sending → Webhooks → "Webhook signing key" nel pannello Mailgun

# ─── Outreach Brand ────────────────────────────────────
BRAND_NAME=WebRadar
BRAND_EMAIL=info@webradar.it
DEMO_BASE_DOMAIN=demo.webradar.it
DEMO_STORAGE_PATH=                   # default: Rails.root/storage/demos

# ─── App URL (per tracking email e link assoluti) ──────
APP_BASE_URL=https://app.webradar.it  # in sviluppo: http://localhost:3000

# ─── GDPR / Opt-out ────────────────────────────────────
OPTOUT_SECRET=changeme_random_string_32chars
