<!DOCTYPE html>
<html lang="it">
  <head>
    <title>WebRadar Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="csrf-token" content="<%= form_authenticity_token %>">
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">

    <%# Navbar %>
    <nav class="bg-white border-b border-gray-200 px-6 py-3 flex items-center justify-between flex-shrink-0">
      <div class="flex items-center gap-6">
        <span class="font-bold text-lg tracking-tight text-emerald-600">WebRadar</span>
        <div class="flex items-center gap-4 text-sm">
          <%= link_to "Campagne", admin_campaigns_path,  class: nav_link_class("campaigns") %>
          <%= link_to "Aziende",  admin_companies_path, class: nav_link_class("companies") %>
          <%= link_to "Lead",     admin_leads_path,     class: nav_link_class("leads") %>
          <%= link_to "Demo",     admin_demos_path,     class: nav_link_class("demos") %>
        </div>
      </div>
      <div class="flex items-center gap-4 text-sm text-gray-500">
        <span><%= current_user.email %></span>
        <%= link_to "Esci", destroy_user_session_path,
              data: { turbo_method: :delete },
              class: "hover:text-red-600" %>
      </div>
    </nav>

    <%# Flash %>
    <% if notice %>
      <div id="flash-notice" class="bg-emerald-50 border-b border-emerald-200 text-emerald-800 px-6 py-3 text-sm">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div id="flash-alert" class="bg-red-50 border-b border-red-200 text-red-800 px-6 py-3 text-sm">
        <%= alert %>
      </div>
    <% end %>

    <%# Contenuto principale %>
    <main class="flex-1 p-6 max-w-7xl mx-auto w-full">
      <%= yield %>
    </main>

  </body>
</html>
