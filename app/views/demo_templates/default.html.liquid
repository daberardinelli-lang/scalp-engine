<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex,nofollow">
  <meta name="description" content="{{ headline }} — {{ company_name }}, {{ city }}">
  <title>{{ company_name }} — Sito Demo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,700;0,800;1,700&display=swap" rel="stylesheet">
  <style>
    /* ── Reset & Base ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0 }
    html { scroll-behavior: smooth; font-size: 16px }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: #1a202c;
      background: #f8f9fa;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── Scroll Reveal ────────────────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-left {
      opacity: 0;
      transform: translateX(-60px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal-left.visible { opacity: 1; transform: translateX(0) }
    .reveal-right {
      opacity: 0;
      transform: translateX(60px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal-right.visible { opacity: 1; transform: translateX(0) }
    .reveal-scale {
      opacity: 0;
      transform: scale(0.85);
      transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal-scale.visible { opacity: 1; transform: scale(1) }

    /* Stagger delays per i children */
    .stagger > *:nth-child(1) { transition-delay: 0s }
    .stagger > *:nth-child(2) { transition-delay: 0.1s }
    .stagger > *:nth-child(3) { transition-delay: 0.2s }
    .stagger > *:nth-child(4) { transition-delay: 0.3s }
    .stagger > *:nth-child(5) { transition-delay: 0.4s }
    .stagger > *:nth-child(6) { transition-delay: 0.5s }
    .stagger > *:nth-child(7) { transition-delay: 0.6s }
    .stagger > *:nth-child(8) { transition-delay: 0.7s }

    /* ── Demo banner ──────────────────────────────────────────── */
    .demo-banner {
      background: linear-gradient(90deg, #0f172a, #1e293b);
      color: #fbbf24;
      text-align: center;
      padding: 10px 20px;
      font-size: 13px;
      letter-spacing: 0.03em;
      position: relative;
      z-index: 200;
    }

    /* ── Navigation ───────────────────────────────────────────── */
    nav {
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(0,0,0,0.06);
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 0 24px;
      transition: box-shadow 0.3s;
    }
    nav.scrolled {
      box-shadow: 0 4px 30px rgba(0,0,0,0.08);
    }
    .nav-inner {
      max-width: 1140px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 68px;
      gap: 16px;
    }
    .nav-brand {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 22px;
      font-weight: 800;
      color: #0f4c35;
      white-space: nowrap;
    }
    .nav-category {
      font-size: 11px;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 500;
      margin-top: 2px;
    }
    .nav-cta {
      background: linear-gradient(135deg, #0f4c35, #16a34a);
      color: #fff;
      padding: 10px 26px;
      border-radius: 50px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
      white-space: nowrap;
      transition: transform 0.3s, box-shadow 0.3s;
      box-shadow: 0 4px 15px rgba(15,76,53,0.3);
    }
    .nav-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(15,76,53,0.4);
    }

    /* ── Layout helpers ────────────────────────────────────────── */
    .container { max-width: 1140px; margin: 0 auto; padding: 0 24px }
    .section { padding: 80px 0; position: relative }
    .section-eyebrow {
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #16a34a;
      margin-bottom: 12px;
    }
    .section-title {
      text-align: center;
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 36px;
      font-weight: 800;
      margin-bottom: 12px;
      color: #111827;
      line-height: 1.2;
    }
    .section-sub {
      text-align: center;
      font-size: 17px;
      color: #6b7280;
      margin-bottom: 52px;
      max-width: 560px;
      margin-left: auto;
      margin-right: auto;
    }

    /* ── Hero ──────────────────────────────────────────────────── */
    .hero {
      position: relative;
      color: #fff;
      padding: 0;
      text-align: center;
      overflow: hidden;
      min-height: 520px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background: linear-gradient(140deg, #0f4c35 0%, #065f46 30%, #047857 60%, #0f4c35 100%);
      background-size: 300% 300%;
      animation: heroGradient 12s ease infinite;
      z-index: 1;
    }
    @keyframes heroGradient {
      0%, 100% { background-position: 0% 50% }
      50% { background-position: 100% 50% }
    }

    /* Blob decorativi animati */
    .hero-blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.2;
      z-index: 2;
      animation: blobFloat 8s ease-in-out infinite;
    }
    .hero-blob-1 {
      width: 400px; height: 400px;
      background: #34d399;
      top: -100px; right: -100px;
      animation-delay: 0s;
    }
    .hero-blob-2 {
      width: 350px; height: 350px;
      background: #fbbf24;
      bottom: -80px; left: -80px;
      animation-delay: -4s;
    }
    .hero-blob-3 {
      width: 250px; height: 250px;
      background: #a78bfa;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      animation-delay: -2s;
    }
    @keyframes blobFloat {
      0%, 100% { transform: translate(0, 0) scale(1) }
      33% { transform: translate(30px, -20px) scale(1.05) }
      66% { transform: translate(-20px, 20px) scale(0.95) }
    }
    .hero-blob-3 {
      animation-name: blobFloatCenter;
    }
    @keyframes blobFloatCenter {
      0%, 100% { transform: translate(-50%, -50%) scale(1) }
      33% { transform: translate(-45%, -55%) scale(1.1) }
      66% { transform: translate(-55%, -45%) scale(0.9) }
    }

    .hero-content {
      position: relative;
      z-index: 10;
      padding: 100px 24px 90px;
      max-width: 900px;
    }
    .hero h1 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(28px, 5vw, 56px);
      font-weight: 800;
      line-height: 1.12;
      margin-bottom: 24px;
    }
    .hero-meta {
      color: #a7f3d0;
      font-size: 17px;
      margin-bottom: 8px;
      font-weight: 500;
    }
    .hero-rating {
      margin-top: 24px;
      font-size: 15px;
      color: #a7f3d0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }
    .hero-stars { color: #fbbf24; font-size: 24px; letter-spacing: 2px }
    .hero-rating-number {
      font-size: 42px;
      font-weight: 900;
      color: #fff;
      line-height: 1;
    }
    .hero-rating-label {
      font-size: 14px;
      color: #a7f3d0;
      text-align: left;
      line-height: 1.3;
    }
    .hero-rating-box {
      display: flex;
      align-items: center;
      gap: 12px;
      background: rgba(255,255,255,0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 16px;
      padding: 16px 24px;
      margin: 28px auto 0;
      width: fit-content;
    }

    .hero-btn {
      display: inline-block;
      background: #fbbf24;
      color: #1a202c;
      padding: 18px 48px;
      border-radius: 50px;
      font-weight: 800;
      font-size: 16px;
      text-decoration: none;
      margin-top: 40px;
      transition: transform 0.3s, box-shadow 0.3s;
      box-shadow: 0 8px 30px rgba(251,191,36,0.35);
      animation: pulse 2.5s ease-in-out infinite;
      letter-spacing: 0.02em;
    }
    .hero-btn:hover {
      transform: translateY(-3px) scale(1.03);
      box-shadow: 0 12px 40px rgba(251,191,36,0.5);
    }
    @keyframes pulse {
      0%, 100% { box-shadow: 0 8px 30px rgba(251,191,36,0.35) }
      50% { box-shadow: 0 8px 50px rgba(251,191,36,0.55) }
    }

    /* ── Hero con foto reale ──────────────────────────────────── */
    .hero-photo { background: #07140e; min-height: 86vh; }
    .hero-photo-bg {
      position: absolute;
      inset: -60px;                 /* margine extra per il parallax */
      background-size: cover;
      background-position: center;
      transform: scale(1.12);
      will-change: transform;
      z-index: 1;
      animation: heroZoom 20s ease-in-out infinite alternate;
    }
    @keyframes heroZoom {
      from { transform: scale(1.12) translate(0, 0) }
      to   { transform: scale(1.22) translate(0, -14px) }
    }
    .hero-overlay {
      position: absolute;
      inset: 0;
      z-index: 2;
      background:
        radial-gradient(70% 60% at 50% 52%, rgba(0,0,0,0.42), transparent 70%),
        linear-gradient(180deg, rgba(7,20,14,0.20) 0%, rgba(7,20,14,0.05) 42%, rgba(7,20,14,0.62) 100%);
    }
    .hero-photo .hero-content {
      text-shadow: 0 2px 24px rgba(0,0,0,0.7), 0 1px 4px rgba(0,0,0,0.5);
      transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
      will-change: transform;
    }
    .hero-photo .hero-meta,
    .hero-photo .hero-rating-label { color: #d1fae5; }

    /* Entrata cinematografica hero (solo se il moto è consentito) */
    @media (prefers-reduced-motion: no-preference) {
      .hero-photo .hero-content > * {
        opacity: 0;
        animation: heroRise 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
      }
      .hero-photo h1              { animation-delay: 0.15s }
      .hero-photo .hero-meta      { animation-delay: 0.45s }
      .hero-photo .hero-rating-box { animation-delay: 0.65s }
      .hero-photo .hero-btn {
        animation: heroRise 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.85s forwards,
                   pulse 2.5s ease-in-out 2s infinite;
      }
    }
    @keyframes heroRise {
      from { opacity: 0; transform: translateY(28px); filter: blur(6px) }
      to   { opacity: 1; transform: translateY(0);    filter: blur(0) }
    }

    /* ── Tilt 3D interattivo (immagini "wow") ─────────────────── */
    .tilt-3d {
      transform-style: preserve-3d;
      transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1),
                  box-shadow 0.25s cubic-bezier(0.16, 1, 0.3, 1);
      will-change: transform;
    }
    .tilt-glare {
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: radial-gradient(circle at var(--gx, 50%) var(--gy, 50%),
                  rgba(255,255,255,0.35), rgba(255,255,255,0) 55%);
      opacity: 0;
      transition: opacity 0.25s;
      pointer-events: none;
      z-index: 4;
    }
    .tilt-3d.tilting .tilt-glare { opacity: 1; }

    /* ── Wave separator ───────────────────────────────────────── */
    .wave-separator {
      position: relative;
      margin-top: -2px;
      line-height: 0;
    }
    .wave-separator svg {
      display: block;
      width: 100%;
      height: 60px;
    }
    .wave-separator-flip {
      margin-top: 0;
      margin-bottom: -2px;
    }
    .wave-separator-flip svg {
      transform: rotate(180deg);
    }

    /* ── About ─────────────────────────────────────────────────── */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }
    .about-text {
      font-size: 17px;
      color: #374151;
      line-height: 1.9;
    }
    .about-image-wrap {
      position: relative;
    }
    .about-image {
      border-radius: 20px;
      overflow: hidden;
      aspect-ratio: 4/3;
      box-shadow: 0 20px 60px rgba(0,0,0,0.15);
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .about-image:hover {
      transform: scale(1.02);
    }
    .about-image img { width: 100%; height: 100%; object-fit: cover; display: block }
    /* Decorazione angolare dietro l'immagine */
    .about-image-wrap::before {
      content: '';
      position: absolute;
      top: -16px;
      right: -16px;
      width: 120px;
      height: 120px;
      border: 3px solid #16a34a;
      border-radius: 20px;
      z-index: -1;
      opacity: 0.3;
    }
    .about-single {
      max-width: 720px;
      margin: 0 auto;
      font-size: 18px;
      color: #374151;
      line-height: 1.9;
      text-align: center;
    }

    /* ── Services ──────────────────────────────────────────────── */
    .services-section { background: #fff }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }
    .service-card {
      background: #fafdfb;
      border: 1px solid #e6efe9;
      border-radius: 14px;
      padding: 24px 22px;
      text-align: left;
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                  box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
                  border-color 0.3s;
      cursor: default;
    }
    .service-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 30px rgba(15,76,53,0.08);
      border-color: #cfe6d8;
    }
    .service-icon {
      width: 40px;
      height: 40px;
      margin: 0 0 14px;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      color: #16a34a;
    }
    .service-icon svg { width: 28px; height: 28px; }
    .service-name {
      font-weight: 700;
      font-size: 16px;
      color: #0f4c35;
      line-height: 1.35;
    }
    .service-desc {
      margin-top: 6px;
      font-size: 14px;
      color: #5b6b62;
      line-height: 1.6;
    }

    /* ── Gallery ───────────────────────────────────────────────── */
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 16px;
    }
    .gallery-item {
      border-radius: 16px;
      overflow: hidden;
      cursor: pointer;
      position: relative;
    }
    .gallery-item img {
      width: 100%;
      height: 240px;
      object-fit: cover;
      display: block;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .gallery-item::after {
      content: '🔍';
      position: absolute;
      inset: 0;
      z-index: 5;
      background: rgba(0,0,0,0.35);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .gallery-item:hover::after { opacity: 1 }
    .gallery-item:hover img { transform: scale(1.08) }
    .gallery-credit { text-align: center; font-size: 12px; color: #9ca3af; margin-top: 20px }

    /* Lightbox */
    .lightbox {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.9);
      z-index: 1000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 40px;
      cursor: zoom-out;
      animation: fadeIn 0.3s;
    }
    .lightbox.active { display: flex }
    .lightbox img {
      max-width: 90vw;
      max-height: 85vh;
      border-radius: 12px;
      object-fit: contain;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }
    .lightbox-close {
      position: absolute;
      top: 20px;
      right: 28px;
      color: #fff;
      font-size: 36px;
      cursor: pointer;
      background: none;
      border: none;
      opacity: 0.7;
      transition: opacity 0.2s;
      z-index: 1001;
    }
    .lightbox-close:hover { opacity: 1 }
    @keyframes fadeIn { from { opacity: 0 } to { opacity: 1 } }

    /* ── Reviews ───────────────────────────────────────────────── */
    .reviews-section { background: #f8fafc }
    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
    }
    .review-card {
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.8);
      border-radius: 20px;
      padding: 32px 28px;
      position: relative;
      box-shadow: 0 4px 24px rgba(0,0,0,0.04);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                  box-shadow 0.4s;
    }
    .review-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.08);
    }
    .review-quote {
      position: absolute;
      top: 16px;
      left: 24px;
      font-size: 72px;
      color: #d1fae5;
      line-height: 1;
      font-family: 'Playfair Display', Georgia, serif;
      opacity: 0.6;
    }
    .review-stars { color: #f59e0b; font-size: 18px; margin-bottom: 14px; letter-spacing: 2px }
    .review-text {
      font-size: 15px;
      color: #374151;
      line-height: 1.75;
      margin-bottom: 18px;
      font-style: italic;
      padding-top: 12px;
    }
    .review-author {
      font-size: 14px;
      font-weight: 700;
      color: #065f46;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .review-author::before {
      content: '';
      display: inline-block;
      width: 24px;
      height: 2px;
      background: #16a34a;
    }

    /* ── Contact (full-bleed map + scheda flottante glass) ─────── */
    .contact-stage {
      position: relative;
      min-height: 600px;
      display: flex;
      align-items: flex-end;       /* scheda ancorata in basso */
      justify-content: flex-start; /* ...a sinistra (asimmetria voluta) */
      padding: 56px;
      overflow: hidden;
    }
    .contact-map-bg { position: absolute; inset: 0; z-index: 1; background: #e5e7eb; }
    .contact-map-bg iframe { width: 100%; height: 100%; border: 0; display: block; }
    .contact-overlay {
      position: absolute; inset: 0; z-index: 2; pointer-events: none;
      background:
        linear-gradient(to top, rgba(7,20,14,0.92) 0%, rgba(7,20,14,0.55) 28%, rgba(7,20,14,0) 58%),
        linear-gradient(to right, rgba(15,76,53,0.5) 0%, rgba(15,76,53,0) 55%);
    }
    /* Blob brand diffuso dietro la scheda (accento non-standard) */
    .contact-accent {
      position: absolute; z-index: 2; bottom: 3%; left: 3%;
      width: 320px; height: 320px; border-radius: 50%;
      background: radial-gradient(circle, #16a34a, #0f4c35 70%);
      filter: blur(80px); opacity: 0.5; pointer-events: none;
    }
    .contact-card {
      position: relative; z-index: 3;
      width: 40%; min-width: 340px; max-width: 480px;
      background: rgba(8,28,20,0.6);
      backdrop-filter: blur(20px) saturate(140%);
      -webkit-backdrop-filter: blur(20px) saturate(140%);
      border: 1px solid rgba(255,255,255,0.22);
      border-radius: 26px;
      padding: 34px 32px;
      box-shadow: 0 28px 70px rgba(0,0,0,0.4);
      color: #fff;
      transition: transform 0.35s cubic-bezier(0.16,1,0.3,1),
                  box-shadow 0.35s cubic-bezier(0.16,1,0.3,1);
    }
    .contact-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 36px 90px rgba(0,0,0,0.5);
    }
    .contact-pill {
      display: inline-block;
      background: rgba(255,255,255,0.14);
      border: 1px solid rgba(255,255,255,0.25);
      color: #d1fae5;
      font-size: 12px; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.08em;
      padding: 6px 14px; border-radius: 50px; margin-bottom: 18px;
    }
    .contact-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(30px, 4vw, 44px);
      font-weight: 800; line-height: 1.08; margin-bottom: 18px; color: #fff;
    }
    .contact-phone {
      display: inline-block;
      font-size: clamp(26px, 3.4vw, 36px);
      font-weight: 800; color: #fff; text-decoration: none;
      letter-spacing: -0.01em; line-height: 1.1;
      transition: color 0.2s;
    }
    .contact-phone:hover { color: #fbbf24; }
    .contact-meta { margin-top: 12px; font-size: 15px; color: #c7e9d6; line-height: 1.6; }
    .contact-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 26px; }
    .contact-cta {
      display: inline-flex; align-items: center; gap: 8px;
      background: #fbbf24; color: #1a202c;
      padding: 14px 26px; border-radius: 50px;
      font-weight: 700; font-size: 15px; text-decoration: none;
      box-shadow: 0 6px 22px rgba(251,191,36,0.35);
      transition: transform 0.25s, box-shadow 0.25s;
    }
    .contact-cta:hover { transform: translateY(-2px); box-shadow: 0 10px 30px rgba(251,191,36,0.5); }
    .contact-cta-wa {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(37,211,102,0.18);
      border: 1px solid rgba(37,211,102,0.65);
      color: #eafff2;
      padding: 13px 22px; border-radius: 50px;
      font-weight: 600; font-size: 15px; text-decoration: none;
      transition: background 0.25s, transform 0.25s;
    }
    .contact-cta-wa svg { fill: #25d366; flex-shrink: 0; }
    .contact-cta-wa:hover { background: rgba(37,211,102,0.32); transform: translateY(-2px); }
    .contact-maplink {
      display: inline-block; margin-top: 18px;
      color: #9fe7c0; font-size: 14px; text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s, color 0.2s;
    }
    .contact-maplink:hover { color: #d1fae5; border-bottom-color: rgba(159,231,192,0.7); }

    /* Fallback senza mappa: scheda centrata su sfondo brand */
    .contact-stage-nomap {
      background: linear-gradient(160deg, #0f4c35, #065f46 55%, #047857);
      align-items: center;
      justify-content: center;
      min-height: 460px;
    }
    .contact-card-center { width: 100%; max-width: 560px; }

    /* ── Floating WhatsApp ────────────────────────────────────── */
    .whatsapp-float {
      position: fixed;
      bottom: 28px;
      right: 28px;
      z-index: 500;
      width: 64px;
      height: 64px;
      background: #25d366;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 6px 24px rgba(37,211,102,0.4);
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.3s, box-shadow 0.3s;
      animation: whatsappBounce 3s ease-in-out infinite;
    }
    .whatsapp-float:hover {
      transform: scale(1.1);
      box-shadow: 0 8px 32px rgba(37,211,102,0.55);
    }
    .whatsapp-float svg {
      width: 34px;
      height: 34px;
      fill: #fff;
    }
    .whatsapp-tooltip {
      position: absolute;
      right: 74px;
      top: 50%;
      transform: translateY(-50%);
      background: #fff;
      color: #1a202c;
      padding: 8px 16px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      white-space: nowrap;
      box-shadow: 0 4px 16px rgba(0,0,0,0.12);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }
    .whatsapp-float:hover .whatsapp-tooltip { opacity: 1 }
    @keyframes whatsappBounce {
      0%, 100% { transform: translateY(0) }
      50% { transform: translateY(-6px) }
    }

    /* ── Footer ────────────────────────────────────────────────── */
    footer {
      background: #0f172a;
      color: #6b7280;
      padding: 44px 24px;
      text-align: center;
      font-size: 13px;
    }
    .footer-badge {
      display: inline-block;
      background: linear-gradient(135deg, #1e293b, #334155);
      border: 1px solid #475569;
      color: #cbd5e1;
      padding: 6px 18px;
      border-radius: 50px;
      font-size: 12px;
      margin-bottom: 18px;
      letter-spacing: 0.04em;
      font-weight: 500;
    }
    footer a { color: #94a3b8; transition: color 0.2s }
    footer a:hover { color: #e2e8f0 }
    .footer-divider { margin: 0 8px; color: #334155 }
    .footer-links {
      display: flex;
      justify-content: center;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
    }

    /* ── Responsive ────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .about-grid { grid-template-columns: 1fr; gap: 32px }
      .about-image-wrap { order: -1 }
      .about-image-wrap::before { display: none }
      .nav-cta { display: none }
      .hero-content { padding: 72px 20px 64px }
      .hero h1 { font-size: 28px }
      .contact-stage { display: block; min-height: 0; padding: 0; overflow: visible }
      .contact-map-bg { position: relative; height: 260px }
      .contact-overlay, .contact-accent { display: none }
      .contact-card {
        width: auto; min-width: 0; max-width: none;
        margin: -48px 16px 0;
        background: rgba(8,28,20,0.92);
        backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
      }
      .contact-stage-nomap { padding: 40px 16px; min-height: 0 }
      .contact-stage-nomap .contact-card { margin: 0 auto }
      .section { padding: 56px 0 }
      .section-title { font-size: 28px }
      .services-grid { grid-template-columns: repeat(2, 1fr); gap: 14px }
      .service-card { padding: 20px 18px }
      .reviews-grid { grid-template-columns: 1fr }
      .gallery-grid { grid-template-columns: 1fr 1fr; gap: 10px }
      .gallery-item img { height: 180px }
      .whatsapp-float { width: 56px; height: 56px; bottom: 20px; right: 20px }
      .whatsapp-tooltip { display: none }
      .hero-rating-box { padding: 12px 18px }
      .hero-rating-number { font-size: 34px }
    }
    @media (max-width: 480px) {
      .services-grid { grid-template-columns: 1fr }
    }
    @media (prefers-reduced-motion: reduce) {
      .contact-card { transition: none }
      .contact-card:hover { transform: none }
    }
  </style>
</head>
<body>

<!-- Demo banner -->
<div class="demo-banner">
  ⚡ Questo è un <strong>sito demo</strong> creato da <strong>{{ brand_name }}</strong> — immagina come potrebbe essere la tua presenza online!
</div>

<!-- Navigation -->
<nav id="mainNav">
  <div class="nav-inner">
    <div>
      <div class="nav-brand">{{ company_name }}</div>
      <div class="nav-category">{{ category_label }}</div>
    </div>
    <a href="#contatti" class="nav-cta">{{ cta_text }}</a>
  </div>
</nav>

<!-- Hero -->
<section class="hero{% if hero_photo != "" %} hero-photo{% endif %}">
  {% if hero_photo != "" %}
  <div class="hero-photo-bg" data-parallax style="background-image:url('{{ hero_photo }}')"></div>
  <div class="hero-overlay"></div>
  {% else %}
  <div class="hero-bg"></div>
  <div class="hero-blob hero-blob-1"></div>
  <div class="hero-blob hero-blob-2"></div>
  <div class="hero-blob hero-blob-3"></div>
  {% endif %}

  <div class="hero-content">
    <h1 id="heroTitle">{{ headline }}</h1>
    <div class="hero-meta">📍 {{ city }}{% if province != "" %}, {{ province }}{% endif %} · {{ category_label }}</div>
    {% if rating_stars != "" %}
    <div class="hero-rating-box">
      <div>
        <div class="hero-stars">{{ rating_stars }}</div>
      </div>
      <div class="hero-rating-number" data-target="{{ maps_rating }}">{{ maps_rating }}</div>
      <div class="hero-rating-label">su 5<br><strong data-count="{{ maps_reviews_count }}">{{ maps_reviews_count }}</strong> recensioni</div>
    </div>
    {% endif %}
    <a href="#contatti" class="hero-btn">{{ cta_text }} →</a>
  </div>
</section>

<!-- Wave after hero -->
<div class="wave-separator">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" fill="#f8f9fa">
    <path d="M0,0 C240,60 480,60 720,30 C960,0 1200,0 1440,30 L1440,60 L0,60 Z"/>
  </svg>
</div>

<!-- About -->
<section class="section">
  <div class="container">
    {% if first_photo != "" %}
    <div class="about-grid">
      <div class="reveal-left">
        <div class="section-eyebrow" style="text-align:left">Chi siamo</div>
        <h2 class="section-title" style="text-align:left;margin-bottom:24px">La nostra storia</h2>
        <p class="about-text">{{ about }}</p>
      </div>
      <div class="about-image-wrap reveal-right">
        <div class="about-image tilt-3d">
          <img src="{{ first_photo }}" alt="{{ company_name }}" loading="eager">
          <span class="tilt-glare"></span>
        </div>
      </div>
    </div>
    {% else %}
    <div class="reveal">
      <div class="section-eyebrow">Chi siamo</div>
      <h2 class="section-title">La nostra storia</h2>
      <div style="height:16px"></div>
      <p class="about-single">{{ about }}</p>
    </div>
    {% endif %}
  </div>
</section>

<!-- Services -->
{% if services.size > 0 %}
<div class="wave-separator-flip wave-separator">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" fill="#fff">
    <path d="M0,0 C240,60 480,60 720,30 C960,0 1200,0 1440,30 L1440,60 L0,60 Z"/>
  </svg>
</div>
<section class="section services-section">
  <div class="container">
    <div class="reveal">
      <div class="section-eyebrow">Servizi</div>
      <h2 class="section-title">{% if services_title != "" %}{{ services_title }}{% else %}I nostri servizi{% endif %}</h2>
      {% if services_intro != "" %}<p class="section-sub">{{ services_intro }}</p>{% endif %}
    </div>
    <div class="services-grid stagger">
      {% for service in services %}
      <div class="service-card reveal-scale">
        <div class="service-icon">{{ service.icon }}</div>
        <div class="service-name">{{ service.name }}</div>
        {% if service.desc != blank %}<p class="service-desc">{{ service.desc }}</p>{% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>
<div class="wave-separator">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" fill="#fff">
    <path d="M0,0 C240,60 480,60 720,30 C960,0 1200,0 1440,30 L1440,60 L0,60 Z"/>
  </svg>
</div>
{% endif %}

<!-- Gallery -->
{% if photos.size > 0 %}
<section class="section">
  <div class="container">
    <div class="reveal">
      <div class="section-eyebrow">Galleria</div>
      <h2 class="section-title">I nostri ambienti</h2>
      <p class="section-sub">Scopri i nostri spazi e la nostra atmosfera</p>
    </div>
    <div class="gallery-grid stagger">
      {% for photo in photos %}
      <div class="gallery-item tilt-3d reveal-scale" onclick="openLightbox(this)">
        <img src="{{ photo }}" alt="Foto {{ company_name }}" loading="lazy">
        <span class="tilt-glare"></span>
      </div>
      {% endfor %}
    </div>
    <p class="gallery-credit">Foto: Google Maps. Diritti riservati ai rispettivi autori.</p>
  </div>
</section>
{% endif %}

<!-- Reviews -->
{% if reviews.size > 0 %}
<section class="section reviews-section">
  <div class="container">
    <div class="reveal">
      <div class="section-eyebrow">Recensioni</div>
      <h2 class="section-title">Cosa dicono i clienti</h2>
      <p class="section-sub">Opinioni reali e verificate su Google Maps</p>
    </div>
    <div class="reviews-grid stagger">
      {% for review in reviews %}
      <div class="review-card reveal-scale">
        <div class="review-quote">"</div>
        <div class="review-stars">{{ review.stars }}</div>
        <p class="review-text">{{ review.text }}</p>
        <div class="review-author">{{ review.author }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Contact -->
