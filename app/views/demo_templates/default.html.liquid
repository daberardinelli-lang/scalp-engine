<!-- ═══ JavaScript ═══ -->
<script>
(function() {
  'use strict';

  // ── Scroll Reveal (IntersectionObserver) ───────────────────
  var revealElements = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    revealElements.forEach(function(el) { observer.observe(el); });
  } else {
    // Fallback: mostra tutto
    revealElements.forEach(function(el) { el.classList.add('visible'); });
  }

  // ── Navbar shadow on scroll ────────────────────────────────
  var nav = document.getElementById('mainNav');
  if (nav) {
    window.addEventListener('scroll', function() {
      nav.classList.toggle('scrolled', window.scrollY > 10);
    }, { passive: true });
  }

  // ── Animated counter (rating) ──────────────────────────────
  var ratingEl = document.querySelector('.hero-rating-number');
  if (ratingEl) {
    var target = parseFloat(ratingEl.getAttribute('data-target'));
    if (!isNaN(target) && target > 0) {
      var current = 0;
      var step = target / 40;
      var timer = setInterval(function() {
        current += step;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        ratingEl.textContent = current.toFixed(1);
      }, 40);
    }
  }

  // ── Animated counter (review count) ────────────────────────
  var countEl = document.querySelector('[data-count]');
  if (countEl) {
    var countTarget = parseInt(countEl.getAttribute('data-count'), 10);
    if (!isNaN(countTarget) && countTarget > 0) {
      var countCurrent = 0;
      var countStep = Math.max(1, Math.ceil(countTarget / 40));
      var countTimer = setInterval(function() {
        countCurrent += countStep;
        if (countCurrent >= countTarget) {
          countCurrent = countTarget;
          clearInterval(countTimer);
        }
        countEl.textContent = countCurrent;
      }, 40);
    }
  }

  // ── Rispetta prefers-reduced-motion ────────────────────────
  var reduceMotion = window.matchMedia &&
    window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Tilt 3D interattivo sulle immagini ─────────────────────
  // Solo desktop con puntatore fine (no touch) e se il moto è consentito.
  var finePointer = window.matchMedia && window.matchMedia('(pointer: fine)').matches;
  if (!reduceMotion && finePointer) {
    var MAX_TILT = 14; // gradi
    document.querySelectorAll('.tilt-3d').forEach(function(card) {
      card.addEventListener('mousemove', function(e) {
        var r  = card.getBoundingClientRect();
        var px = (e.clientX - r.left) / r.width;   // 0..1
        var py = (e.clientY - r.top) / r.height;   // 0..1
        var rx = (0.5 - py) * MAX_TILT * 2;
        var ry = (px - 0.5) * MAX_TILT * 2;
        card.classList.add('tilting');
        card.style.transform =
          'perspective(850px) rotateX(' + rx.toFixed(2) + 'deg) rotateY(' +
          ry.toFixed(2) + 'deg) scale(1.06)';
        // Ombra dinamica: si proietta nella direzione opposta all'inclinazione
        var sx = (0.5 - px) * 36;
        var sy = (0.5 - py) * 36 + 28;
        card.style.boxShadow =
          sx.toFixed(0) + 'px ' + sy.toFixed(0) + 'px 55px rgba(0,0,0,0.32)';
        card.style.setProperty('--gx', (px * 100).toFixed(1) + '%');
        card.style.setProperty('--gy', (py * 100).toFixed(1) + '%');
      });
      card.addEventListener('mouseleave', function() {
        card.classList.remove('tilting');
        card.style.transform = '';
        card.style.boxShadow = '';
      });
    });
  }

  // ── Parallax hero (foto reale) ─────────────────────────────
  var heroBg = document.querySelector('.hero-photo-bg[data-parallax]');
  if (heroBg && !reduceMotion) {
    var hero = heroBg.closest('.hero');
    var heroContent = hero && hero.querySelector('.hero-content');
    // Parallax sul movimento del mouse: sfondo e contenuto si muovono in
    // direzioni opposte → senso di profondità (effetto 3D).
    if (finePointer && hero) {
      hero.addEventListener('mousemove', function(e) {
        var r  = hero.getBoundingClientRect();
        var dx = ((e.clientX - r.left) / r.width - 0.5) * 24;
        var dy = ((e.clientY - r.top) / r.height - 0.5) * 24;
        heroBg.style.transform = 'scale(1.16) translate(' + dx.toFixed(1) + 'px,' + dy.toFixed(1) + 'px)';
        if (heroContent) {
          heroContent.style.transform =
            'translate(' + (-dx * 0.45).toFixed(1) + 'px,' + (-dy * 0.45).toFixed(1) + 'px)';
        }
      });
      hero.addEventListener('mouseleave', function() {
        if (heroContent) heroContent.style.transform = '';
      });
    }
    // Parallax sullo scroll
    window.addEventListener('scroll', function() {
      var offset = window.scrollY * 0.25;
      heroBg.style.backgroundPosition = 'center calc(50% + ' + offset.toFixed(0) + 'px)';
    }, { passive: true });
  }
})();

// ── Lightbox ───────────────────────────────────────────────
function openLightbox(el) {
  var img = el.querySelector('img');
  if (!img) return;
  var lb = document.getElementById('lightbox');
  document.getElementById('lightboxImg').src = img.src;
  lb.classList.add('active');
  document.body.style.overflow = 'hidden';
}
function closeLightbox() {
  var lb = document.getElementById('lightbox');
  lb.classList.remove('active');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeLightbox();
});
</script>

</body>
</html>
