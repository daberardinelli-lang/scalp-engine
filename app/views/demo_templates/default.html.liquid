<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="robots" content="noindex,nofollow">
  <meta name="description" content="{{ headline }} — {{ company_name }}, {{ city }}">
  <title>{{ company_name }} — Sito Demo</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,700;0,800;1,700&display=swap" rel="stylesheet">
  <style>
    /* ── Reset & Base ─────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0 }
    html { scroll-behavior: smooth; font-size: 16px }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      color: #1a202c;
      background: #f8f9fa;
      line-height: 1.6;
      overflow-x: hidden;
    }

    /* ── Scroll Reveal ────────────────────────────────────────── */
    .reveal {
      opacity: 0;
      transform: translateY(40px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }
    .reveal-left {
      opacity: 0;
      transform: translateX(-60px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal-left.visible { opacity: 1; transform: translateX(0) }
    .reveal-right {
      opacity: 0;
      transform: translateX(60px);
      transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal-right.visible { opacity: 1; transform: translateX(0) }
    .reveal-scale {
      opacity: 0;
      transform: scale(0.85);
      transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .reveal-scale.visible { opacity: 1; transform: scale(1) }

    /* Stagger delays per i children */
    .stagger > *:nth-child(1) { transition-delay: 0s }
    .stagger > *:nth-child(2) { transition-delay: 0.1s }
    .stagger > *:nth-child(3) { transition-delay: 0.2s }
    .stagger > *:nth-child(4) { transition-delay: 0.3s }
    .stagger > *:nth-child(5) { transition-delay: 0.4s }
    .stagger > *:nth-child(6) { transition-delay: 0.5s }
    .stagger > *:nth-child(7) { transition-delay: 0.6s }
    .stagger > *:nth-child(8) { transition-delay: 0.7s }

    /* ── Demo banner ──────────────────────────────────────────── */
    .demo-banner {
      background: linear-gradient(90deg, #0f172a, #1e293b);
      color: #fbbf24;
      text-align: center;
      padding: 10px 20px;
      font-size: 13px;
      letter-spacing: 0.03em;
      position: relative;
      z-index: 200;
    }

    /* ── Navigation ───────────────────────────────────────────── */
    nav {
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid rgba(0,0,0,0.06);
      position: sticky;
      top: 0;
      z-index: 100;
      padding: 0 24px;
      transition: box-shadow 0.3s;
    }
    nav.scrolled {
      box-shadow: 0 4px 30px rgba(0,0,0,0.08);
    }
    .nav-inner {
      max-width: 1140px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 68px;
      gap: 16px;
    }
    .nav-brand {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 22px;
      font-weight: 800;
      color: #0f4c35;
      white-space: nowrap;
    }
    .nav-category {
      font-size: 11px;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-weight: 500;
      margin-top: 2px;
    }
    .nav-cta {
      background: linear-gradient(135deg, #0f4c35, #16a34a);
      color: #fff;
      padding: 10px 26px;
      border-radius: 50px;
      text-decoration: none;
      font-size: 14px;
      font-weight: 600;
      white-space: nowrap;
      transition: transform 0.3s, box-shadow 0.3s;
      box-shadow: 0 4px 15px rgba(15,76,53,0.3);
    }
    .nav-cta:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(15,76,53,0.4);
    }

    /* ── Layout helpers ────────────────────────────────────────── */
    .container { max-width: 1140px; margin: 0 auto; padding: 0 24px }
    .section { padding: 80px 0; position: relative }
    .section-eyebrow {
      text-align: center;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: #16a34a;
      margin-bottom: 12px;
    }
    .section-title {
      text-align: center;
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 36px;
      font-weight: 800;
      margin-bottom: 12px;
      color: #111827;
      line-height: 1.2;
    }
    .section-sub {
      text-align: center;
      font-size: 17px;
      color: #6b7280;
      margin-bottom: 52px;
      max-width: 560px;
      margin-left: auto;
      margin-right: auto;
    }

    /* ── Hero ──────────────────────────────────────────────────── */
    .hero {
      position: relative;
      color: #fff;
      padding: 0;
      text-align: center;
      overflow: hidden;
      min-height: 520px;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .hero-bg {
      position: absolute;
      inset: 0;
      background: linear-gradient(140deg, #0f4c35 0%, #065f46 30%, #047857 60%, #0f4c35 100%);
      background-size: 300% 300%;
      animation: heroGradient 12s ease infinite;
      z-index: 1;
    }
    @keyframes heroGradient {
      0%, 100% { background-position: 0% 50% }
      50% { background-position: 100% 50% }
    }

    /* Blob decorativi animati */
    .hero-blob {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      opacity: 0.2;
      z-index: 2;
      animation: blobFloat 8s ease-in-out infinite;
    }
    .hero-blob-1 {
      width: 400px; height: 400px;
      background: #34d399;
      top: -100px; right: -100px;
      animation-delay: 0s;
    }
    .hero-blob-2 {
      width: 350px; height: 350px;
      background: #fbbf24;
      bottom: -80px; left: -80px;
      animation-delay: -4s;
    }
    .hero-blob-3 {
      width: 250px; height: 250px;
      background: #a78bfa;
      top: 50%; left: 50%;
      transform: translate(-50%, -50%);
      animation-delay: -2s;
    }
    @keyframes blobFloat {
      0%, 100% { transform: translate(0, 0) scale(1) }
      33% { transform: translate(30px, -20px) scale(1.05) }
      66% { transform: translate(-20px, 20px) scale(0.95) }
    }
    .hero-blob-3 {
      animation-name: blobFloatCenter;
    }
    @keyframes blobFloatCenter {
      0%, 100% { transform: translate(-50%, -50%) scale(1) }
      33% { transform: translate(-45%, -55%) scale(1.1) }
      66% { transform: translate(-55%, -45%) scale(0.9) }
    }

    .hero-content {
      position: relative;
      z-index: 10;
      padding: 100px 24px 90px;
      max-width: 900px;
    }
    .hero h1 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: clamp(28px, 5vw, 56px);
      font-weight: 800;
      line-height: 1.12;
      margin-bottom: 24px;
    }
    .hero-meta {
      color: #a7f3d0;
      font-size: 17px;
      margin-bottom: 8px;
      font-weight: 500;
    }
    .hero-rating {
      margin-top: 24px;
      font-size: 15px;
      color: #a7f3d0;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
    }
    .hero-stars { color: #fbbf24; font-size: 24px; letter-spacing: 2px }
    .hero-rating-number {
      font-size: 42px;
      font-weight: 900;
      color: #fff;
      line-height: 1;
    }
    .hero-rating-label {
      font-size: 14px;
      color: #a7f3d0;
      text-align: left;
      line-height: 1.3;
    }
    .hero-rating-box {
      display: flex;
      align-items: center;
      gap: 12px;
      background: rgba(255,255,255,0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 16px;
      padding: 16px 24px;
      margin: 28px auto 0;
      width: fit-content;
    }

    .hero-btn {
      display: inline-block;
      background: #fbbf24;
      color: #1a202c;
      padding: 18px 48px;
      border-radius: 50px;
      font-weight: 800;
      font-size: 16px;
      text-decoration: none;
      margin-top: 40px;
      transition: transform 0.3s, box-shadow 0.3s;
      box-shadow: 0 8px 30px rgba(251,191,36,0.35);
      animation: pulse 2.5s ease-in-out infinite;
      letter-spacing: 0.02em;
    }
    .hero-btn:hover {
      transform: translateY(-3px) scale(1.03);
      box-shadow: 0 12px 40px rgba(251,191,36,0.5);
    }
    @keyframes pulse {
      0%, 100% { box-shadow: 0 8px 30px rgba(251,191,36,0.35) }
      50% { box-shadow: 0 8px 50px rgba(251,191,36,0.55) }
    }

    /* ── Wave separator ───────────────────────────────────────── */
    .wave-separator {
      position: relative;
      margin-top: -2px;
      line-height: 0;
    }
    .wave-separator svg {
      display: block;
      width: 100%;
      height: 60px;
    }
    .wave-separator-flip {
      margin-top: 0;
      margin-bottom: -2px;
    }
    .wave-separator-flip svg {
      transform: rotate(180deg);
    }

    /* ── About ─────────────────────────────────────────────────── */
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }
    .about-text {
      font-size: 17px;
      color: #374151;
      line-height: 1.9;
    }
    .about-image-wrap {
      position: relative;
    }
    .about-image {
      border-radius: 20px;
      overflow: hidden;
      aspect-ratio: 4/3;
      box-shadow: 0 20px 60px rgba(0,0,0,0.15);
      transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .about-image:hover {
      transform: scale(1.02);
    }
    .about-image img { width: 100%; height: 100%; object-fit: cover; display: block }
    /* Decorazione angolare dietro l'immagine */
    .about-image-wrap::before {
      content: '';
      position: absolute;
      top: -16px;
      right: -16px;
      width: 120px;
      height: 120px;
      border: 3px solid #16a34a;
      border-radius: 20px;
      z-index: -1;
      opacity: 0.3;
    }
    .about-single {
      max-width: 720px;
      margin: 0 auto;
      font-size: 18px;
      color: #374151;
      line-height: 1.9;
      text-align: center;
    }

    /* ── Services ──────────────────────────────────────────────── */
    .services-section { background: #fff }
    .services-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 24px;
    }
    .service-card {
      background: linear-gradient(145deg, #f0fdf4, #ecfdf5);
      border: 1px solid #bbf7d0;
      border-radius: 20px;
      padding: 36px 24px 32px;
      text-align: center;
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                  box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
      cursor: default;
      position: relative;
      overflow: hidden;
    }
    .service-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, transparent 40%, rgba(16,185,129,0.08));
      opacity: 0;
      transition: opacity 0.4s;
    }
    .service-card:hover::before { opacity: 1 }
    .service-card:hover {
      transform: translateY(-8px);
      box-shadow: 0 20px 40px rgba(15,76,53,0.12);
    }
    .service-icon {
      width: 56px;
      height: 56px;
      margin: 0 auto 16px;
      background: linear-gradient(135deg, #0f4c35, #16a34a);
      border-radius: 16px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      color: #fff;
      box-shadow: 0 4px 12px rgba(15,76,53,0.25);
    }
    .service-name {
      font-weight: 600;
      font-size: 15px;
      color: #065f46;
      line-height: 1.4;
      position: relative;
    }

    /* ── Gallery ───────────────────────────────────────────────── */
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 16px;
    }
    .gallery-item {
      border-radius: 16px;
      overflow: hidden;
      cursor: pointer;
      position: relative;
    }
    .gallery-item img {
      width: 100%;
      height: 240px;
      object-fit: cover;
      display: block;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .gallery-item::after {
      content: '🔍';
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0.35);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 32px;
      opacity: 0;
      transition: opacity 0.3s;
    }
    .gallery-item:hover::after { opacity: 1 }
    .gallery-item:hover img { transform: scale(1.08) }
    .gallery-credit { text-align: center; font-size: 12px; color: #9ca3af; margin-top: 20px }

    /* Lightbox */
    .lightbox {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.9);
      z-index: 1000;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 40px;
      cursor: zoom-out;
      animation: fadeIn 0.3s;
    }
    .lightbox.active { display: flex }
    .lightbox img {
      max-width: 90vw;
      max-height: 85vh;
      border-radius: 12px;
      object-fit: contain;
      box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    }
    .lightbox-close {
      position: absolute;
      top: 20px;
      right: 28px;
      color: #fff;
      font-size: 36px;
      cursor: pointer;
      background: none;
      border: none;
      opacity: 0.7;
      transition: opacity 0.2s;
      z-index: 1001;
    }
    .lightbox-close:hover { opacity: 1 }
    @keyframes fadeIn { from { opacity: 0 } to { opacity: 1 } }

    /* ── Reviews ───────────────────────────────────────────────── */
    .reviews-section { background: #f8fafc }
    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 24px;
    }
    .review-card {
      background: rgba(255,255,255,0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,0.8);
      border-radius: 20px;
      padding: 32px 28px;
      position: relative;
      box-shadow: 0 4px 24px rgba(0,0,0,0.04);
      transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1),
                  box-shadow 0.4s;
    }
    .review-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 40px rgba(0,0,0,0.08);
    }
    .review-quote {
      position: absolute;
      top: 16px;
      left: 24px;
      font-size: 72px;
      color: #d1fae5;
      line-height: 1;
      font-family: 'Playfair Display', Georgia, serif;
      opacity: 0.6;
    }
    .review-stars { color: #f59e0b; font-size: 18px; margin-bottom: 14px; letter-spacing: 2px }
    .review-text {
      font-size: 15px;
      color: #374151;
      line-height: 1.75;
      margin-bottom: 18px;
      font-style: italic;
      padding-top: 12px;
    }
    .review-author {
      font-size: 14px;
      font-weight: 700;
      color: #065f46;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .review-author::before {
      content: '';
      display: inline-block;
      width: 24px;
      height: 2px;
      background: #16a34a;
    }

    /* ── Contact ───────────────────────────────────────────────── */
    .contact-wrapper {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 24px 64px rgba(0,0,0,0.15);
      max-width: 1000px;
      margin: 0 auto;
    }
    .contact-box {
      background: linear-gradient(160deg, #0f4c35, #065f46, #047857);
      color: #fff;
      padding: 56px 48px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .contact-box h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 30px;
      font-weight: 800;
      margin-bottom: 12px;
    }
    .contact-box > p { color: #a7f3d0; font-size: 16px; margin-bottom: 36px }
    .contact-info { display: flex; flex-direction: column; gap: 20px; margin-bottom: 36px }
    .contact-item {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .contact-icon {
      width: 44px;
      height: 44px;
      background: rgba(255,255,255,0.1);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      flex-shrink: 0;
    }
    .contact-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: #6ee7b7 }
    .contact-value { font-size: 16px; font-weight: 600; color: #fff }
    .contact-btn {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: #fbbf24;
      color: #1a202c;
      padding: 16px 36px;
      border-radius: 50px;
      font-weight: 700;
      font-size: 16px;
      text-decoration: none;
      transition: transform 0.3s, box-shadow 0.3s;
      box-shadow: 0 4px 20px rgba(251,191,36,0.3);
      width: fit-content;
    }
    .contact-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 30px rgba(251,191,36,0.45);
    }
    .contact-map {
      min-height: 360px;
      background: #e5e7eb;
    }
    .contact-map iframe {
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }

    /* Fallback se non c'e' mappa */
    .contact-box-full {
      background: linear-gradient(160deg, #0f4c35, #065f46, #047857);
      color: #fff;
      border-radius: 24px;
      padding: 60px 52px;
      text-align: center;
      max-width: 800px;
      margin: 0 auto;
      box-shadow: 0 24px 64px rgba(15,76,53,0.25);
    }
    .contact-box-full .contact-info {
      flex-direction: row;
      justify-content: center;
      flex-wrap: wrap;
      gap: 32px;
    }
    .contact-box-full .contact-item {
      flex-direction: column;
      text-align: center;
    }
    .contact-box-full .contact-btn {
      margin: 0 auto;
    }

    /* ── Floating WhatsApp ────────────────────────────────────── */
    .whatsapp-float {
      position: fixed;
      bottom: 28px;
      right: 28px;
      z-index: 500;
      width: 64px;
      height: 64px;
      background: #25d366;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 6px 24px rgba(37,211,102,0.4);
      cursor: pointer;
      text-decoration: none;
      transition: transform 0.3s, box-shadow 0.3s;
      animation: whatsappBounce 3s ease-in-out infinite;
    }
    .whatsapp-float:hover {
      transform: scale(1.1);
      box-shadow: 0 8px 32px rgba(37,211,102,0.55);
    }
    .whatsapp-float svg {
      width: 34px;
      height: 34px;
      fill: #fff;
    }
    .whatsapp-tooltip {
      position: absolute;
      right: 74px;
      top: 50%;
      transform: translateY(-50%);
      background: #fff;
      color: #1a202c;
      padding: 8px 16px;
      border-radius: 10px;
      font-size: 13px;
      font-weight: 600;
      white-space: nowrap;
      box-shadow: 0 4px 16px rgba(0,0,0,0.12);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }
    .whatsapp-float:hover .whatsapp-tooltip { opacity: 1 }
    @keyframes whatsappBounce {
      0%, 100% { transform: translateY(0) }
      50% { transform: translateY(-6px) }
    }

    /* ── Footer ────────────────────────────────────────────────── */
    footer {
      background: #0f172a;
      color: #6b7280;
      padding: 44px 24px;
      text-align: center;
      font-size: 13px;
    }
    .footer-badge {
      display: inline-block;
      background: linear-gradient(135deg, #1e293b, #334155);
      border: 1px solid #475569;
      color: #cbd5e1;
      padding: 6px 18px;
      border-radius: 50px;
      font-size: 12px;
      margin-bottom: 18px;
      letter-spacing: 0.04em;
      font-weight: 500;
    }
    footer a { color: #94a3b8; transition: color 0.2s }
    footer a:hover { color: #e2e8f0 }
    .footer-divider { margin: 0 8px; color: #334155 }
    .footer-links {
      display: flex;
      justify-content: center;
      gap: 8px;
      flex-wrap: wrap;
      align-items: center;
    }

    /* ── Responsive ────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .about-grid { grid-template-columns: 1fr; gap: 32px }
      .about-image-wrap { order: -1 }
      .about-image-wrap::before { display: none }
      .nav-cta { display: none }
      .hero-content { padding: 72px 20px 64px }
      .hero h1 { font-size: 28px }
      .contact-wrapper { grid-template-columns: 1fr }
      .contact-map { min-height: 280px }
      .contact-box { padding: 40px 28px }
      .section { padding: 56px 0 }
      .section-title { font-size: 28px }
      .services-grid { grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 16px }
      .service-card { padding: 28px 16px 24px }
      .reviews-grid { grid-template-columns: 1fr }
      .gallery-grid { grid-template-columns: 1fr 1fr; gap: 10px }
      .gallery-item img { height: 180px }
      .whatsapp-float { width: 56px; height: 56px; bottom: 20px; right: 20px }
      .whatsapp-tooltip { display: none }
      .hero-rating-box { padding: 12px 18px }
      .hero-rating-number { font-size: 34px }
    }
  </style>
</head>
<body>

<!-- Demo banner -->
<div class="demo-banner">
  ⚡ Questo è un <strong>sito demo</strong> creato da <strong>{{ brand_name }}</strong> — immagina come potrebbe essere la tua presenza online!
</div>

<!-- Navigation -->
<nav id="mainNav">
  <div class="nav-inner">
    <div>
      <div class="nav-brand">{{ company_name }}</div>
      <div class="nav-category">{{ category_label }}</div>
    </div>
    <a href="#contatti" class="nav-cta">{{ cta_text }}</a>
  </div>
</nav>

<!-- Hero -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-blob hero-blob-1"></div>
  <div class="hero-blob hero-blob-2"></div>
  <div class="hero-blob hero-blob-3"></div>

  <div class="hero-content">
    <h1 id="heroTitle">{{ headline }}</h1>
    <div class="hero-meta">📍 {{ city }}{% if province != "" %}, {{ province }}{% endif %} · {{ category_label }}</div>
    {% if rating_stars != "" %}
    <div class="hero-rating-box">
      <div>
        <div class="hero-stars">{{ rating_stars }}</div>
      </div>
      <div class="hero-rating-number" data-target="{{ maps_rating }}">{{ maps_rating }}</div>
      <div class="hero-rating-label">su 5<br><strong data-count="{{ maps_reviews_count }}">{{ maps_reviews_count }}</strong> recensioni</div>
    </div>
    {% endif %}
    <a href="#contatti" class="hero-btn">{{ cta_text }} →</a>
  </div>
</section>

<!-- Wave after hero -->
<div class="wave-separator">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" fill="#f8f9fa">
    <path d="M0,0 C240,60 480,60 720,30 C960,0 1200,0 1440,30 L1440,60 L0,60 Z"/>
  </svg>
</div>

<!-- About -->
<section class="section">
  <div class="container">
    {% if first_photo != "" %}
    <div class="about-grid">
      <div class="reveal-left">
        <div class="section-eyebrow" style="text-align:left">Chi siamo</div>
        <h2 class="section-title" style="text-align:left;margin-bottom:24px">La nostra storia</h2>
        <p class="about-text">{{ about }}</p>
      </div>
      <div class="about-image-wrap reveal-right">
        <div class="about-image">
          <img src="{{ first_photo }}" alt="{{ company_name }}" loading="eager">
        </div>
      </div>
    </div>
    {% else %}
    <div class="reveal">
      <div class="section-eyebrow">Chi siamo</div>
      <h2 class="section-title">La nostra storia</h2>
      <div style="height:16px"></div>
      <p class="about-single">{{ about }}</p>
    </div>
    {% endif %}
  </div>
</section>

<!-- Services -->
{% if services.size > 0 %}
<div class="wave-separator-flip wave-separator">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" fill="#fff">
    <path d="M0,0 C240,60 480,60 720,30 C960,0 1200,0 1440,30 L1440,60 L0,60 Z"/>
  </svg>
</div>
<section class="section services-section">
  <div class="container">
    <div class="reveal">
      <div class="section-eyebrow">Servizi</div>
      <h2 class="section-title">Cosa offriamo</h2>
      <p class="section-sub">Tutto quello che serve per soddisfare le tue esigenze</p>
    </div>
    <div class="services-grid stagger">
      {% for service in services %}
      <div class="service-card reveal-scale">
        <div class="service-icon">✦</div>
        <div class="service-name">{{ service }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
<div class="wave-separator">
  <svg viewBox="0 0 1440 60" preserveAspectRatio="none" fill="#fff">
    <path d="M0,0 C240,60 480,60 720,30 C960,0 1200,0 1440,30 L1440,60 L0,60 Z"/>
  </svg>
</div>
{% endif %}

<!-- Gallery -->
{% if photos.size > 0 %}
<section class="section">
  <div class="container">
    <div class="reveal">
      <div class="section-eyebrow">Galleria</div>
      <h2 class="section-title">I nostri ambienti</h2>
      <p class="section-sub">Scopri i nostri spazi e la nostra atmosfera</p>
    </div>
    <div class="gallery-grid stagger">
      {% for photo in photos %}
      <div class="gallery-item reveal-scale" onclick="openLightbox(this)">
        <img src="{{ photo }}" alt="Foto {{ company_name }}" loading="lazy">
      </div>
      {% endfor %}
    </div>
    <p class="gallery-credit">Foto: Google Maps. Diritti riservati ai rispettivi autori.</p>
  </div>
</section>
{% endif %}

<!-- Reviews -->
{% if reviews.size > 0 %}
<section class="section reviews-section">
  <div class="container">
    <div class="reveal">
      <div class="section-eyebrow">Recensioni</div>
      <h2 class="section-title">Cosa dicono i clienti</h2>
      <p class="section-sub">Opinioni reali e verificate su Google Maps</p>
    </div>
    <div class="reviews-grid stagger">
      {% for review in reviews %}
      <div class="review-card reveal-scale">
        <div class="review-quote">"</div>
        <div class="review-stars">{{ review.stars }}</div>
        <p class="review-text">{{ review.text }}</p>
        <div class="review-author">{{ review.author }}</div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Contact -->
<section class="section" id="contatti">
  <div class="container">
    <div class="reveal">
      <div class="section-eyebrow">Contatti</div>
      <h2 class="section-title" style="margin-bottom:48px">Vieni a trovarci</h2>
    </div>

    {% if google_place_id != "" %}
    <div class="contact-wrapper reveal-scale">
      <div class="contact-box">
        <h2>{{ cta_text }}</h2>
        <p>Siamo qui per aiutarti — contattaci oggi stesso!</p>
        <div class="contact-info">
          {% if phone != "" %}
          <div class="contact-item">
            <div class="contact-icon">📞</div>
            <div>
              <div class="contact-label">Telefono</div>
              <div class="contact-value">{{ phone }}</div>
            </div>
          </div>
          {% endif %}
          <div class="contact-item">
            <div class="contact-icon">📍</div>
            <div>
              <div class="contact-label">Dove siamo</div>
              <div class="contact-value">{{ city }}{% if province != "" %}, {{ province }}{% endif %}</div>
            </div>
          </div>
          {% if address != "" %}
          <div class="contact-item">
            <div class="contact-icon">🏠</div>
            <div>
              <div class="contact-label">Indirizzo</div>
              <div class="contact-value">{{ address }}</div>
            </div>
          </div>
          {% endif %}
        </div>
        {% if phone != "" %}
        <a href="tel:{{ phone_clean }}" class="contact-btn">📞 Chiama ora</a>
        {% endif %}
      </div>
      <div class="contact-map">
        <iframe
          src="https://www.google.com/maps/embed/v1/place?key={{ google_maps_embed_key }}&q=place_id:{{ google_place_id }}"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mappa {{ company_name }}"
          allowfullscreen>
        </iframe>
      </div>
    </div>
    {% else %}
    <div class="contact-box-full reveal-scale">
      <h2>{{ cta_text }}</h2>
      <p style="color:#a7f3d0;font-size:16px;margin-bottom:36px">Siamo qui per aiutarti — contattaci oggi stesso!</p>
      <div class="contact-info">
        {% if phone != "" %}
        <div class="contact-item">
          <div class="contact-icon">📞</div>
          <div>
            <div class="contact-label">Telefono</div>
            <div class="contact-value">{{ phone }}</div>
          </div>
        </div>
        {% endif %}
        <div class="contact-item">
          <div class="contact-icon">📍</div>
          <div>
            <div class="contact-label">Dove siamo</div>
            <div class="contact-value">{{ city }}{% if province != "" %}, {{ province }}{% endif %}</div>
          </div>
        </div>
        {% if google_maps_url != "" %}
        <div class="contact-item">
          <div class="contact-icon">🗺️</div>
          <div>
            <div class="contact-label">Mappa</div>
            <div class="contact-value">
              <a href="{{ google_maps_url }}" target="_blank" rel="noopener" style="color:#6ee7b7">Apri su Maps ↗</a>
            </div>
          </div>
        </div>
        {% endif %}
      </div>
      {% if phone != "" %}
      <a href="tel:{{ phone_clean }}" class="contact-btn">📞 Chiama ora</a>
      {% endif %}
    </div>
    {% endif %}
  </div>
</section>

<!-- Footer -->
<footer>
  <div class="footer-badge">🌐 Sito demo — non ancora online</div>
  <div style="margin-bottom:8px;color:#e2e8f0;font-weight:700;font-size:16px;font-family:'Playfair Display',Georgia,serif">{{ company_name }}</div>
  <div style="margin-bottom:18px">
    {{ city }}{% if province != "" %}, {{ province }}{% endif %}
    {% if phone != "" %}
    <span class="footer-divider">·</span> {{ phone }}
    {% endif %}
  </div>
  <div style="margin-bottom:14px">
    Demo generata il {{ generated_at }} da
    <a href="mailto:{{ brand_email }}"><strong>{{ brand_name }}</strong></a>
    per mostrarti il potenziale della tua presenza online.
  </div>
  <div class="footer-links">
    <a href="mailto:{{ brand_email }}">Contatta {{ brand_name }}</a>
    <span class="footer-divider">·</span>
    <a href="{{ privacy_url }}" target="_blank" rel="noopener">Privacy Policy</a>
    <span class="footer-divider">·</span>
    <span>Dati e foto Google Maps © Google</span>
  </div>
</footer>

<!-- Floating WhatsApp Button -->
{% if whatsapp_url != "" %}
<a href="{{ whatsapp_url }}" target="_blank" rel="noopener" class="whatsapp-float" title="Scrivici su WhatsApp">
  <svg viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
  <span class="whatsapp-tooltip">Scrivici su WhatsApp</span>
</a>
{% endif %}

<!-- Lightbox overlay -->
<div class="lightbox" id="lightbox" onclick="closeLightbox()">
  <button class="lightbox-close" aria-label="Chiudi">&times;</button>
  <img id="lightboxImg" src="" alt="Foto ingrandita">
</div>

<!-- ═══ JavaScript ═══ -->
<script>
(function() {
  'use strict';

  // ── Scroll Reveal (IntersectionObserver) ───────────────────
  var revealElements = document.querySelectorAll('.reveal, .reveal-left, .reveal-right, .reveal-scale');
  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    revealElements.forEach(function(el) { observer.observe(el); });
  } else {
    // Fallback: mostra tutto
    revealElements.forEach(function(el) { el.classList.add('visible'); });
  }

  // ── Navbar shadow on scroll ────────────────────────────────
  var nav = document.getElementById('mainNav');
  if (nav) {
    window.addEventListener('scroll', function() {
      nav.classList.toggle('scrolled', window.scrollY > 10);
    }, { passive: true });
  }

  // ── Animated counter (rating) ──────────────────────────────
  var ratingEl = document.querySelector('.hero-rating-number');
  if (ratingEl) {
    var target = parseFloat(ratingEl.getAttribute('data-target'));
    if (!isNaN(target) && target > 0) {
      var current = 0;
      var step = target / 40;
      var timer = setInterval(function() {
        current += step;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        ratingEl.textContent = current.toFixed(1);
      }, 40);
    }
  }

  // ── Animated counter (review count) ────────────────────────
  var countEl = document.querySelector('[data-count]');
  if (countEl) {
    var countTarget = parseInt(countEl.getAttribute('data-count'), 10);
    if (!isNaN(countTarget) && countTarget > 0) {
      var countCurrent = 0;
      var countStep = Math.max(1, Math.ceil(countTarget / 40));
      var countTimer = setInterval(function() {
        countCurrent += countStep;
        if (countCurrent >= countTarget) {
          countCurrent = countTarget;
          clearInterval(countTimer);
        }
        countEl.textContent = countCurrent;
      }, 40);
    }
  }
})();

// ── Lightbox ───────────────────────────────────────────────
function openLightbox(el) {
  var img = el.querySelector('img');
  if (!img) return;
  var lb = document.getElementById('lightbox');
  document.getElementById('lightboxImg').src = img.src;
  lb.classList.add('active');
  document.body.style.overflow = 'hidden';
}
function closeLightbox() {
  var lb = document.getElementById('lightbox');
  lb.classList.remove('active');
  document.body.style.overflow = '';
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') closeLightbox();
});
</script>

</body>
</html>
