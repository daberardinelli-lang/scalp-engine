<div class="min-h-screen flex items-center justify-center bg-gray-50">
  <div class="w-full max-w-md">

    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-emerald-600">WebRadar</h1>
      <p class="mt-2 text-sm text-gray-500">Sistema di outreach automatizzato</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
      <h2 class="text-xl font-semibold text-gray-800 mb-6">Accedi</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

        <div class="mb-4">
          <%= f.label :email, "Email", class: "form-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "form-input", placeholder: "admin@webradar.local" %>
        </div>

        <div class="mb-6">
          <%= f.label :password, "Password", class: "form-label" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "form-input", placeholder: "••••••••" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center mb-6">
            <%= f.check_box :remember_me, class: "h-4 w-4 text-emerald-600 rounded border-gray-300" %>
            <%= f.label :remember_me, "Ricordami", class: "ml-2 text-sm text-gray-600" %>
          </div>
        <% end %>

        <%= f.submit "Accedi", class: "btn-primary w-full justify-center cursor-pointer" %>

      <% end %>
    </div>

  </div>
</div>
