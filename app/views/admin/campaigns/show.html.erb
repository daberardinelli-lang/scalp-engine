<%# app/views/admin/campaigns/show.html.erb %>

<div class="mb-6">
  <div class="flex items-center gap-2 text-sm text-gray-500 mb-2">
    <%= link_to "Campagne", admin_campaigns_path, class: "hover:text-gray-700" %>
    <span>/</span>
    <span class="text-gray-900"><%= @campaign.name %></span>
  </div>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
        <%= @campaign.name %>
        <span class="text-sm font-medium px-2 py-0.5 rounded-full <%= @campaign.active? ? 'bg-emerald-100 text-emerald-700' : 'bg-gray-100 text-gray-500' %>">
          <%= @campaign.active? ? "Attiva" : "Inattiva" %>
        </span>
      </h1>
      <% if @campaign.description.present? %>
        <p class="text-sm text-gray-500 mt-1"><%= @campaign.description %></p>
      <% end %>
    </div>
    <div class="flex gap-2 shrink-0">
      <%= link_to "✏ Modifica", edit_admin_campaign_path(@campaign),
            class: "bg-white border border-gray-300 hover:border-gray-400 text-gray-700 text-sm font-medium px-4 py-2 rounded-lg transition" %>
      <%= button_to @campaign.active? ? "⏸ Disattiva" : "▶ Attiva",
            toggle_active_admin_campaign_path(@campaign),
            class: "#{@campaign.active? ? 'bg-red-50 hover:bg-red-100 text-red-600' : 'bg-emerald-50 hover:bg-emerald-100 text-emerald-700'} text-sm font-medium px-4 py-2 rounded-lg transition border border-gray-200" %>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

  <%# Sidebar config %>
  <div class="space-y-4">

    <%# Stats %>
    <div class="bg-white border border-gray-200 rounded-lg p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Statistiche</h3>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-gray-500">Prospect totali</dt>
          <dd class="font-semibold text-gray-900"><%= @stats[:total] %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Contattati</dt>
          <dd class="font-semibold text-yellow-700"><%= @stats[:contacted] %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-gray-500">Convertiti</dt>
          <dd class="font-semibold text-emerald-700"><%= @stats[:converted] %></dd>
        </div>
      </dl>
    </div>

    <%# Configurazione %>
    <div class="bg-white border border-gray-200 rounded-lg p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Configurazione</h3>
      <dl class="space-y-2 text-sm">
        <% if @campaign.operator_profile.present? %>
          <div>
            <dt class="text-gray-500 text-xs">👤 Operatore</dt>
            <dd class="font-medium text-gray-800"><%= @campaign.operator_profile %></dd>
          </div>
        <% end %>
        <% if @campaign.target_profile.present? %>
          <div>
            <dt class="text-gray-500 text-xs">🎯 Target</dt>
            <dd class="font-medium text-gray-800"><%= @campaign.target_profile %></dd>
          </div>
        <% end %>
        <div>
          <dt class="text-gray-500 text-xs">🔍 Discovery</dt>
          <dd class="font-medium text-gray-800"><%= @campaign.discovery_source_label %></dd>
        </div>
        <% if @campaign.discovery_query.present? %>
          <div>
            <dt class="text-gray-500 text-xs">🔎 Query</dt>
            <dd><code class="bg-gray-100 text-gray-700 px-1.5 py-0.5 rounded text-xs"><%= @campaign.discovery_query %></code></dd>
          </div>
        <% end %>
        <div>
          <dt class="text-gray-500 text-xs">📧 Template email</dt>
          <dd class="font-medium text-gray-800"><%= @campaign.email_body_template.presence || "web_agency (default)" %></dd>
        </div>
        <div class="flex gap-2 pt-1">
          <% if @campaign.use_ai_content? %>
            <span class="bg-amber-100 text-amber-700 text-xs px-2 py-0.5 rounded-full">✦ AI content</span>
          <% end %>
          <% if @campaign.use_demo? %>
            <span class="bg-violet-100 text-violet-700 text-xs px-2 py-0.5 rounded-full">🏗 Demo</span>
          <% end %>
        </div>
      </dl>
    </div>

    <%# Azioni rapide %>
    <div class="bg-white border border-gray-200 rounded-lg p-4">
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Avvia Discovery</h3>
      <%= form_with url: discover_admin_companies_path, method: :post, local: true, class: "space-y-3" do |f| %>
        <%= f.hidden_field :campaign_id, value: @campaign.id %>
        <div>
          <%= f.label :location, "Location", class: "block text-xs font-medium text-gray-600 mb-1" %>
          <%= f.text_field :location, placeholder: "Es. Roma, Italia",
                class: "w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
        </div>
        <div>
          <%= f.label :radius, "Raggio (km)", class: "block text-xs font-medium text-gray-600 mb-1" %>
          <%= f.select :radius,
                [[5, 5_000], [10, 10_000], [15, 15_000], [25, 25_000], [50, 50_000]].map { |km, m| ["#{km} km", m] },
                { selected: 15_000 },
                class: "w-full border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
        </div>
        <p class="text-xs text-gray-400">
          Query: <strong><%= @campaign.discovery_query.presence || @campaign.target_profile.presence || "—" %></strong>
        </p>
        <%= f.submit "🔍 Avvia Discovery",
              class: "w-full bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium py-2 rounded-lg transition cursor-pointer" %>
      <% end %>
    </div>
  </div>

  <%# Ultimi prospect %>
  <div class="lg:col-span-2">
    <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
      <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
        <h3 class="font-semibold text-gray-800">Ultimi prospect (<%= @stats[:total] %>)</h3>
        <%= link_to "Vedi tutti →", admin_companies_path(campaign_id: @campaign.id),
              class: "text-sm text-emerald-600 hover:text-emerald-800 font-medium" %>
      </div>

      <% if @companies.empty? %>
        <div class="p-8 text-center text-gray-400 text-sm">
          Nessun prospect trovato. Avvia la discovery dalla sidebar.
        </div>
      <% else %>
        <table class="w-full text-sm">
          <thead class="bg-gray-50 text-xs text-gray-500 uppercase">
            <tr>
              <th class="px-4 py-2 text-left font-medium">Nome</th>
              <th class="px-4 py-2 text-left font-medium">Città</th>
              <th class="px-4 py-2 text-left font-medium">Email</th>
              <th class="px-4 py-2 text-left font-medium">Stato</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @companies.each do |company| %>
              <tr class="hover:bg-gray-50 transition">
                <td class="px-4 py-2.5">
                  <%= link_to company.name, admin_company_path(company),
                        class: "font-medium text-gray-900 hover:text-emerald-700" %>
                </td>
                <td class="px-4 py-2.5 text-gray-500"><%= company.city %></td>
                <td class="px-4 py-2.5 text-gray-500 text-xs">
                  <%= company.email.present? ? company.email : '<span class="text-gray-300">—</span>'.html_safe %>
                </td>
                <td class="px-4 py-2.5">
                  <%= status_badge(company.status) %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>
  </div>

</div>
