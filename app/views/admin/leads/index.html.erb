<%# app/views/admin/leads/index.html.erb %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Lead</h1>
    <p class="text-sm text-gray-500 mt-1"><%= @total_count %> lead totali</p>
  </div>
</div>

<%# Statistiche %>
<div class="grid grid-cols-3 sm:grid-cols-6 gap-3 mb-6">
  <% [
    ["Totali",    @stats[:total],     "bg-gray-50",   "text-gray-700"],
    ["Inviati",   @stats[:sent],      "bg-indigo-50", "text-indigo-700"],
    ["Aperti",    @stats[:opened],    "bg-amber-50",  "text-amber-700"],
    ["Click",     @stats[:clicked],   "bg-emerald-50","text-emerald-700"],
    ["Opt-out",   @stats[:opted_out], "bg-red-50",    "text-red-700"],
    ["Convertiti",@stats[:converted], "bg-emerald-50","text-emerald-800"]
  ].each do |label, count, bg, text| %>
    <div class="<%= bg %> border border-gray-200 rounded-lg p-3 text-center">
      <div class="text-2xl font-bold <%= text %>"><%= count %></div>
      <div class="text-xs text-gray-500 mt-0.5"><%= label %></div>
    </div>
  <% end %>
</div>

<%# Filtri %>
<div class="bg-white border border-gray-200 rounded-lg p-4 mb-4">
  <%= form_with url: admin_leads_path, method: :get, local: true, class: "flex flex-wrap gap-3 items-end" do |f| %>
    <div>
      <%= f.label :outcome, "Outcome", class: "block text-xs font-medium text-gray-600 mb-1" %>
      <%= f.select :outcome,
            [["Tutti", ""]] + Lead::OUTCOMES.map { |o| [o.humanize, o] },
            { selected: params[:outcome] },
            class: "border border-gray-300 rounded px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500" %>
    </div>
    <div class="flex items-end gap-2">
      <label class="flex items-center gap-1.5 text-sm text-gray-600 pb-1">
        <%= f.check_box :opened, { checked: params[:opened] == "1" }, "1", "0" %>
        Solo aperte
      </label>
      <label class="flex items-center gap-1.5 text-sm text-gray-600 pb-1">
        <%= f.check_box :clicked, { checked: params[:clicked] == "1" }, "1", "0" %>
        Solo click
      </label>
    </div>
    <%= f.submit "Filtra", class: "bg-gray-700 hover:bg-gray-800 text-white text-sm font-medium px-4 py-1.5 rounded cursor-pointer" %>
    <% if params[:outcome].present? || params[:opened].present? || params[:clicked].present? %>
      <%= link_to "Reset", admin_leads_path, class: "text-sm text-gray-500 hover:text-gray-700 py-1.5" %>
    <% end %>
  <% end %>
</div>

<%# Tabella %>
<div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
  <% if @leads.any? %>
    <table class="min-w-full divide-y divide-gray-200 text-sm">
      <thead class="bg-gray-50 text-xs font-medium text-gray-500 uppercase tracking-wide">
        <tr>
          <th class="px-4 py-3 text-left">Azienda</th>
          <th class="px-4 py-3 text-left">Email</th>
          <th class="px-4 py-3 text-left">Inviata</th>
          <th class="px-4 py-3 text-center">Aperta</th>
          <th class="px-4 py-3 text-center">Click</th>
          <th class="px-4 py-3 text-left">Outcome</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @leads.each do |lead| %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-4 py-3">
              <div class="font-medium text-gray-900"><%= lead.company.name %></div>
              <div class="text-xs text-gray-400"><%= lead.company.city %></div>
            </td>
            <td class="px-4 py-3 text-gray-600 text-xs"><%= lead.company.email %></td>
            <td class="px-4 py-3 text-gray-500 text-xs">
              <% if lead.email_sent_at.present? %>
                <%= lead.email_sent_at.strftime("%d/%m/%Y %H:%M") %>
              <% else %>
                <span class="text-gray-300">Non inviata</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-center">
              <% if lead.opened? %>
                <span class="text-amber-500" title="<%= lead.email_opened_at.strftime('%d/%m %H:%M') %>">★</span>
              <% else %>
                <span class="text-gray-200">—</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-center">
              <% if lead.clicked? %>
                <span class="text-emerald-500" title="<%= lead.link_clicked_at.strftime('%d/%m %H:%M') %>">✓</span>
              <% else %>
                <span class="text-gray-200">—</span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <span class="px-2 py-0.5 rounded-full text-xs font-medium
                <%= lead.outcome == 'converted' ? 'bg-emerald-100 text-emerald-700' :
                    lead.outcome == 'opted_out'  ? 'bg-red-100 text-red-600' :
                    lead.outcome == 'interested' ? 'bg-blue-100 text-blue-700' :
                    'bg-gray-100 text-gray-600' %>">
                <%= lead.outcome %>
              </span>
            </td>
            <td class="px-4 py-3 text-right">
              <%= link_to "Dettaglio →", admin_lead_path(lead),
                    class: "text-emerald-600 hover:text-emerald-800 font-medium" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <%# Paginazione %>
    <% if @total_pages > 1 %>
      <div class="px-4 py-3 border-t border-gray-200 flex items-center justify-between text-sm text-gray-600">
        <span>Pagina <%= @current_page %> di <%= @total_pages %></span>
        <div class="flex gap-2">
          <% if @current_page > 1 %>
            <%= link_to "← Precedente",
                  admin_leads_path(page: @current_page - 1, outcome: params[:outcome]),
                  class: "px-3 py-1 border border-gray-300 rounded hover:bg-gray-50" %>
          <% end %>
          <% if @current_page < @total_pages %>
            <%= link_to "Successiva →",
                  admin_leads_path(page: @current_page + 1, outcome: params[:outcome]),
                  class: "px-3 py-1 border border-gray-300 rounded hover:bg-gray-50" %>
          <% end %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-16 text-gray-400">
      <div class="text-4xl mb-3">📧</div>
      <p class="font-medium">Nessun lead</p>
      <p class="text-sm mt-1">Invia le prime email di outreach per vedere i lead qui.</p>
    </div>
  <% end %>
</div>
