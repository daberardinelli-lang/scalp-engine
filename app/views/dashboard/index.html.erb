<%# app/views/dashboard/index.html.erb %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
  <p class="text-sm text-gray-500 mt-1">Benvenuto, <%= current_user.email %> — <%= Time.current.strftime("%d %B %Y") %></p>
</div>

<%# ── Metriche top ─────────────────────────────────────────────────── %>
<div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">
  <div class="bg-white border border-gray-200 rounded-xl p-5">
    <div class="text-xs text-gray-400 uppercase tracking-wide mb-1">Aziende totali</div>
    <div class="text-3xl font-bold text-gray-900"><%= @total_companies %></div>
    <div class="text-xs text-gray-400 mt-1">nel database</div>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl p-5">
    <div class="text-xs text-gray-400 uppercase tracking-wide mb-1">Demo deployate</div>
    <div class="text-3xl font-bold text-violet-600"><%= @demos_deployed %></div>
    <div class="text-xs text-gray-400 mt-1"><%= @total_views %> visualizzazioni totali</div>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl p-5">
    <div class="text-xs text-gray-400 uppercase tracking-wide mb-1">Email inviate</div>
    <div class="text-3xl font-bold text-indigo-600"><%= @email_stats[:total_sent] %></div>
    <div class="text-xs text-gray-400 mt-1"><%= @email_stats[:sent_month] %> ultimi 30 gg</div>
  </div>
  <div class="bg-white border border-gray-200 rounded-xl p-5">
    <div class="text-xs text-gray-400 uppercase tracking-wide mb-1">Convertite</div>
    <div class="text-3xl font-bold text-emerald-600"><%= @conversions[:converted] %></div>
    <div class="text-xs text-gray-400 mt-1"><%= @conversions[:replied] %> hanno risposto</div>
  </div>
</div>

<%# ── Pipeline + email metrics ────────────────────────────────────── %>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

  <%# Pipeline aziendale %>
  <div class="bg-white border border-gray-200 rounded-xl p-6">
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-5">Pipeline</h2>
    <% steps = [
      ["Scoperte",       @pipeline["discovered"],  "bg-gray-400"],
      ["Arricchite",     @pipeline["enriched"],    "bg-blue-500"],
      ["Demo pronte",    @pipeline["demo_built"],  "bg-violet-500"],
      ["Contattate",     @pipeline["contacted"],   "bg-indigo-500"],
      ["Hanno risposto", @pipeline["replied"],     "bg-amber-500"],
      ["Convertite",     @pipeline["converted"],   "bg-emerald-500"],
      ["Opt-out",        @pipeline["opted_out"],   "bg-red-400"]
    ] %>
    <div class="space-y-3">
      <% max_val = [steps.map { |_, v, _| v }.max, 1].max %>
      <% steps.each do |label, count, color| %>
        <div class="flex items-center gap-3">
          <div class="w-28 text-xs text-gray-500 text-right"><%= label %></div>
          <div class="flex-1 bg-gray-100 rounded-full h-5 overflow-hidden">
            <div class="<%= color %> h-5 rounded-full transition-all duration-500"
                 style="width:<%= [(count.to_f / max_val * 100).round, 2].max %>%"></div>
          </div>
          <div class="w-8 text-sm font-semibold text-gray-700 text-right"><%= count %></div>
        </div>
      <% end %>
    </div>
    <div class="mt-4 pt-4 border-t border-gray-100 text-right">
      <%= link_to "Gestisci aziende →", admin_companies_path, class: "text-sm text-emerald-600 hover:text-emerald-800 font-medium" %>
    </div>
  </div>

  <%# Email tracking metrics %>
  <div class="bg-white border border-gray-200 rounded-xl p-6">
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide mb-5">Email tracking</h2>
    <div class="space-y-4">
      <div>
        <div class="flex justify-between text-sm mb-1">
          <span class="text-gray-600">Aperte</span>
          <span class="font-semibold"><%= @email_stats[:total_opened] %> (<%= @email_stats[:open_rate] %>%)</span>
        </div>
        <div class="bg-gray-100 rounded-full h-2.5">
          <div class="bg-amber-400 h-2.5 rounded-full" style="width:<%= [@email_stats[:open_rate], 100].min %>%"></div>
        </div>
      </div>
      <div>
        <div class="flex justify-between text-sm mb-1">
          <span class="text-gray-600">Click su demo</span>
          <span class="font-semibold"><%= @email_stats[:total_clicked] %> (<%= @email_stats[:click_rate] %>%)</span>
        </div>
        <div class="bg-gray-100 rounded-full h-2.5">
          <div class="bg-emerald-500 h-2.5 rounded-full" style="width:<%= [@email_stats[:click_rate], 100].min %>%"></div>
        </div>
      </div>
    </div>
    <div class="mt-5 grid grid-cols-2 gap-3">
      <div class="bg-indigo-50 rounded-lg p-3 text-center">
        <div class="text-xl font-bold text-indigo-700"><%= @email_stats[:total_sent] %></div>
        <div class="text-xs text-gray-500 mt-0.5">Inviate</div>
      </div>
      <div class="bg-amber-50 rounded-lg p-3 text-center">
        <div class="text-xl font-bold text-amber-700"><%= @email_stats[:total_opened] %></div>
        <div class="text-xs text-gray-500 mt-0.5">Aperte</div>
      </div>
      <div class="bg-emerald-50 rounded-lg p-3 text-center">
        <div class="text-xl font-bold text-emerald-700"><%= @email_stats[:total_clicked] %></div>
        <div class="text-xs text-gray-500 mt-0.5">Click</div>
      </div>
      <div class="bg-red-50 rounded-lg p-3 text-center">
        <div class="text-xl font-bold text-red-600"><%= @email_stats[:total_opted_out] %></div>
        <div class="text-xs text-gray-500 mt-0.5">Opt-out</div>
      </div>
    </div>
    <div class="mt-4 pt-4 border-t border-gray-100 text-right">
      <%= link_to "Gestisci lead →", admin_leads_path, class: "text-sm text-emerald-600 hover:text-emerald-800 font-medium" %>
    </div>
  </div>

</div>

<%# ── Attività recente ─────────────────────────────────────────────── %>
<div class="bg-white border border-gray-200 rounded-xl p-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-sm font-semibold text-gray-700 uppercase tracking-wide">Attività recente (Lead)</h2>
    <%= link_to "Vedi tutti →", admin_leads_path, class: "text-sm text-emerald-600 hover:text-emerald-800" %>
  </div>
  <% if @recent_leads.any? %>
    <div class="space-y-3">
      <% @recent_leads.each do |lead| %>
        <div class="flex items-start gap-3 py-2 border-b border-gray-50 last:border-0">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2">
              <span class="font-medium text-sm text-gray-900 truncate"><%= lead.company.name %></span>
              <span class="text-xs text-gray-400"><%= lead.company.city %></span>
            </div>
            <div class="flex items-center gap-2 mt-0.5 text-xs text-gray-400">
              <% if lead.email_sent_at.present? %>
                <span>📧 <%= lead.email_sent_at.strftime("%d/%m") %></span>
              <% end %>
              <% if lead.opened? %>
                <span class="text-amber-600">👁 Aperta</span>
              <% end %>
              <% if lead.clicked? %>
                <span class="text-emerald-600">🖱 Click demo</span>
              <% end %>
            </div>
          </div>
          <div class="flex-shrink-0 flex items-center gap-2">
            <span class="text-xs px-2 py-0.5 rounded-full <%= lead.outcome == 'converted' ? 'bg-emerald-100 text-emerald-700' : lead.outcome == 'opted_out' ? 'bg-red-100 text-red-600' : 'bg-gray-100 text-gray-600' %>">
              <%= lead.outcome %>
            </span>
            <%= link_to "→", admin_lead_path(lead), class: "text-gray-400 hover:text-gray-600" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-sm text-gray-400 italic text-center py-8">Nessun lead ancora. Avvia la pipeline per iniziare.</p>
  <% end %>
</div>
